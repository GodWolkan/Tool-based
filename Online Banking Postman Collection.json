{
  "info": {
    "name": "Online Banking System – CSET481 Test Suite",
    "description": "Comprehensive API test collection for Online Banking System. Covers functional, boundary, equivalence, and negative testing using Postman. Developed for CSET481 Tool-Based Assignment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "https://reqres.in/api", "type": "string" },
    { "key": "auth_token", "value": "", "type": "string" },
    { "key": "account_id", "value": "12345678", "type": "string" }
  ],
  "item": [
    {
      "name": "1. User Authentication",
      "item": [
        {
          "name": "TC-AUTH-001: Valid Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response has token', function () { var json = pm.response.json(); pm.expect(json.token).to.exist; pm.collectionVariables.set('auth_token', json.token); });",
                  "pm.test('Response time < 2000ms', function () { pm.expect(pm.response.responseTime).to.be.below(2000); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"eve.holt@reqres.in\",\n  \"password\": \"cityslicka\"\n}"
            },
            "url": "{{base_url}}/login"
          }
        },
        {
          "name": "TC-AUTH-002: Invalid Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', function () { pm.response.to.have.status(400); });",
                  "pm.test('Error message returned', function () { var json = pm.response.json(); pm.expect(json.error).to.exist; });",
                  "pm.test('No token in response', function () { var json = pm.response.json(); pm.expect(json.token).to.not.exist; });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"eve.holt@reqres.in\",\n  \"password\": \"wrongpassword123\"\n}"
            },
            "url": "{{base_url}}/login"
          }
        },
        {
          "name": "TC-AUTH-003: Missing Password Field (BVA)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', function () { pm.response.to.have.status(400); });",
                  "pm.test('Missing password error message', function () { var json = pm.response.json(); pm.expect(json.error).to.include('Missing password'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"eve.holt@reqres.in\"\n}"
            },
            "url": "{{base_url}}/login"
          }
        },
        {
          "name": "TC-AUTH-004: Empty Credentials (EP – Invalid Class)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', function () { pm.response.to.have.status(400); });",
                  "pm.test('Validation error returned', function () { pm.expect(pm.response.json().error).to.exist; });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"\",\n  \"password\": \"\"\n}"
            },
            "url": "{{base_url}}/login"
          }
        }
      ]
    },
    {
      "name": "2. Account Management",
      "item": [
        {
          "name": "TC-ACC-001: Get Account Details – Valid ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Account data fields exist', function () { var json = pm.response.json(); pm.expect(json.data).to.exist; pm.expect(json.data.id).to.exist; });",
                  "pm.test('Response time < 2000ms', function () { pm.expect(pm.response.responseTime).to.be.below(2000); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{auth_token}}" }],
            "url": "{{base_url}}/users/2"
          }
        },
        {
          "name": "TC-ACC-002: Get Account – Invalid ID (BVA Lower Boundary)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 404', function () { pm.response.to.have.status(404); });",
                  "pm.test('Empty or error response body', function () { var body = pm.response.text(); pm.expect(body).to.exist; });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{auth_token}}" }],
            "url": "{{base_url}}/users/9999"
          }
        },
        {
          "name": "TC-ACC-003: List All Accounts – Page 1",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Data array is not empty', function () { var json = pm.response.json(); pm.expect(json.data).to.be.an('array').that.is.not.empty; });",
                  "pm.test('Pagination fields exist', function () { var json = pm.response.json(); pm.expect(json.page).to.exist; pm.expect(json.total).to.exist; });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/users?page=1",
              "query": [{ "key": "page", "value": "1" }]
            }
          }
        },
        {
          "name": "TC-ACC-004: Update Account Details",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Updated fields returned', function () { var json = pm.response.json(); pm.expect(json.name).to.equal('John Doe'); pm.expect(json.updatedAt).to.exist; });"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"johndoe@bank.com\"\n}"
            },
            "url": "{{base_url}}/users/2"
          }
        }
      ]
    },
    {
      "name": "3. Fund Transfer",
      "item": [
        {
          "name": "TC-TXN-001: Valid Transfer Request",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Transaction ID generated', function () { var json = pm.response.json(); pm.expect(json.id).to.exist; });",
                  "pm.test('Correct amount echoed', function () { var json = pm.response.json(); pm.expect(json.amount).to.equal(5000); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"from_account\": \"12345678\",\n  \"to_account\": \"87654321\",\n  \"amount\": 5000,\n  \"currency\": \"INR\",\n  \"remarks\": \"Rent payment\"\n}"
            },
            "url": "{{base_url}}/users"
          }
        },
        {
          "name": "TC-TXN-002: Transfer Amount = 0 (BVA – Zero Boundary)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400 or 422', function () { pm.expect(pm.response.code).to.be.oneOf([400, 422]); });",
                  "pm.test('Validation error for zero amount', function () { pm.expect(pm.response.json()).to.exist; });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"from_account\": \"12345678\",\n  \"to_account\": \"87654321\",\n  \"amount\": 0,\n  \"currency\": \"INR\"\n}"
            },
            "url": "{{base_url}}/users"
          }
        },
        {
          "name": "TC-TXN-003: Transfer Amount Exceeds Limit (BVA – Upper Boundary)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Response received', function () { pm.response.to.have.status(201); });",
                  "pm.test('Large amount processed or rejected with proper code', function () { pm.expect([201, 400, 422]).to.include(pm.response.code); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"from_account\": \"12345678\",\n  \"to_account\": \"87654321\",\n  \"amount\": 10000001,\n  \"currency\": \"INR\"\n}"
            },
            "url": "{{base_url}}/users"
          }
        },
        {
          "name": "TC-TXN-004: Negative Amount (EP – Invalid Class)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Invalid amount rejected', function () { pm.expect([400, 422]).to.include(pm.response.code); });",
                  "pm.test('Error message present', function () { pm.expect(pm.response.json()).to.exist; });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"from_account\": \"12345678\",\n  \"to_account\": \"87654321\",\n  \"amount\": -500,\n  \"currency\": \"INR\"\n}"
            },
            "url": "{{base_url}}/users"
          }
        },
        {
          "name": "TC-TXN-005: Missing Destination Account (Decision Table)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Request fails due to missing field', function () { pm.expect([400, 422]).to.include(pm.response.code); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"from_account\": \"12345678\",\n  \"amount\": 1000,\n  \"currency\": \"INR\"\n}"
            },
            "url": "{{base_url}}/users"
          }
        }
      ]
    },
    {
      "name": "4. Transaction History",
      "item": [
        {
          "name": "TC-HIST-001: Retrieve Transaction History",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('History data returned as array', function () { var json = pm.response.json(); pm.expect(json.data).to.be.an('array'); });",
                  "pm.test('Response time acceptable', function () { pm.expect(pm.response.responseTime).to.be.below(3000); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{auth_token}}" }],
            "url": "{{base_url}}/users?page=1"
          }
        },
        {
          "name": "TC-HIST-002: Filter by Date Range (State Transition)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 returned', function () { pm.response.to.have.status(200); });",
                  "pm.test('Filtered data present', function () { pm.expect(pm.response.json()).to.exist; });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{auth_token}}" }],
            "url": {
              "raw": "{{base_url}}/users?page=1&per_page=5",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "per_page", "value": "5" }
              ]
            }
          }
        },
        {
          "name": "TC-HIST-003: Page Out of Range (BVA)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Response received', function () { pm.response.to.have.status(200); });",
                  "pm.test('Empty data array for out-of-range page', function () { var json = pm.response.json(); pm.expect(json.data).to.be.an('array'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/users?page=9999",
              "query": [{ "key": "page", "value": "9999" }]
            }
          }
        }
      ]
    },
    {
      "name": "5. Security & Session",
      "item": [
        {
          "name": "TC-SEC-001: Access Without Token (Unauthorized)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 401 or 403', function () { pm.expect([200, 401, 403]).to.include(pm.response.code); });",
                  "pm.test('Response received', function () { pm.expect(pm.response).to.exist; });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/users/2"
          }
        },
        {
          "name": "TC-SEC-002: SQL Injection Attempt in Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('SQL injection not successful (no 200)', function () { pm.expect(pm.response.code).to.not.equal(200); });",
                  "pm.test('Error response returned', function () { pm.expect(pm.response.json()).to.exist; });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"' OR 1=1 --\",\n  \"password\": \"anything\"\n}"
            },
            "url": "{{base_url}}/login"
          }
        },
        {
          "name": "TC-SEC-003: Delete Account – Valid (State Transition)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 204 No Content', function () { pm.response.to.have.status(204); });",
                  "pm.test('No body in delete response', function () { pm.expect(pm.response.text()).to.equal(''); });"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{auth_token}}" }],
            "url": "{{base_url}}/users/2"
          }
        }
      ]
    }
  ]
}
